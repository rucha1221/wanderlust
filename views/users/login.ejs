<% layout("/layouts/boilerplate") -%>

<div class="row mt-3">
    <div class="col-6 offset-3">
        <h1>Login on Wanderlust</h1>
        <form action="/login" method="post" class="needs-validation" novalidate>
            <div class="mb-3">
                <label for="username" class="form-label">Username</label>
                <input type="text" id="username" placeholder="enter username" name="username" class="form-control" required>
                
                <div class="invalid-feedback">Username is required</div>
            </div>

            <div class="mb-3">
                <label for="password" class="form-label">Password</label>
                <input type="password" id="password" placeholder="enter password" name="password" class="form-control" required>
                
                <div class="invalid-feedback">Password is required</div>
            </div>

            <button class="btn btn-success">Login</button>
        </form>
    </div>
</div>