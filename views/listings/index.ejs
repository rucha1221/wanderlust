<% layout("/layouts/boilerplate") -%>
    <!-- <h3 class="mt-3">All Listings</h3> -->
    <!-- <form method="get" action="/listings/new">
        <button>Create New Listing</button>
    </form> -->

    <div id="filters">
        <div class="filter">
            <a href="/listings">
                <div><i class="fa-solid fa-fire" style="color: rgb(0, 0, 0);"></i></div>
                <p>All</p>
            </a>
        </div>

        <div class="filter">
            <a href="/listings?category=rooms">
                <div><i class="fa-solid fa-bed" style="color: rgb(0, 0, 0);"></i></div>
                <p>Rooms</p>
            </a>
        </div>

        <div class="filter">
            <a href="/listings?category=cities">
                <div><i class="fa-duotone fa-solid fa-mountain-city" style="--fa-primary-color: rgb(255, 193, 7); --fa-secondary-color: rgb(255, 193, 7);"></i></div>
                <p>Iconic Cities</p>
            </a>
        </div>

        <div class="filter">
            <a href="/listings?category=mountains">
                <div><i class="fa-solid fa-mountain" style="color: rgb(0, 0, 0);"></i></div>
                <p>Mountains</p>
            </a>
        </div>

        <div class="filter">
            <a href="/listings?category=luxury">
                <div><i class="fa-solid fa-crown" style="color: rgb(0, 0, 0);"></i></div>
                <p>Luxury</p>
            </a>
        </div>

        <div class="filter">
            <a href="/listings?category=pool">
                <div><i class="fa-solid fa-person-swimming"></i></div>
                <p>Amasing Pools</p>
            </a>
        </div>

        <div class="filter">
            <a href="/listings?category=Lakefront">
                <div><i class="fa-sharp fa-solid fa-water" style="color: rgb(0, 0, 0);"></i></div>
                <p>Lakefront</p>
            </a>
        </div>

        <div class="filter">
            <a href="/listings?category=historic">
                <div><i class="fa-solid fa-cow"></i></div>
                <p>Historic</p>
            </a>
        </div>

        <div class="filter">
            <a href="/listings?category=arctic">
                <div><i class="fa-solid fa-snowflake" style="color: rgb(0, 0, 0);"></i></div>
                <p>Arctic</p>
            </a>
        </div>

        <div class="filter">
            <a href="/listings?category=beach">
                <div><i class="fa-solid fa-umbrella-beach" style="color: rgb(0, 0, 0);"></i></div>
                <p>Beaches</p>
            </a>
        </div>

        <div class="tax-switch">
            <div class="form-check-reverse form-switch">
            <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckChecked">
            <label class="form-check-label" for="flexSwitchCheckChecked">Display total after taxes</label>
            </div>
        </div>
    </div>
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">
        <% for(let listing of allListings){ %>
        <a href="/listings/<%= listing._id %>" class="listing-link">
            <div class="card col listing-card">
            <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image">
            <div class="card-img-overlay"></div>
            <div class="card-body">
                <p class="card-text"><b><%= listing.title %></b><br><%= listing.price.toLocaleString("en-IN") %> / night</p>
                <i class="tax-info"> +18% GST</i>
            </div>
            </div>
        </a>
    <% } %>
    </div>


<script>
    let taxSwitch = document.getElementById("flexSwitchCheckChecked");

    taxSwitch.addEventListener("click", () =>{
        let tax = document.getElementsByClassName("tax-info");
        for(let info of tax){
            if(info.style.display != "inline"){
                info.style.display = "inline";
            }
            else{
                info.style.display = "none";
            }
        } 
    });
</script> 
